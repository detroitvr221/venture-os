# ══════════════════════════════════════════════════════════════
# Northbridge Digital — Environment Variables
# Copy to .env.local and fill in your values
# ══════════════════════════════════════════════════════════════

# === Supabase (REQUIRED) ===
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# === OpenAI (REQUIRED — primary model provider) ===
OPENAI_API_KEY=sk-proj-your-key

# === MiniMax (REQUIRED — default model on OpenClaw) ===
MINIMAX_API_KEY=sk-cp-your-minimax-key

# === Nexos AI (optional — free tier model) ===
NEXOS_API_KEY=nexos-team-your-key

# === OpenClaw (REQUIRED — agent gateway) ===
OPENCLAW_GATEWAY_URL=https://claw.thenorthbridgemi.com
OPENCLAW_API_KEY=vos-hooks-token-2026
OPENCLAW_GATEWAY_TOKEN=vos-gw-token-2026
OPENCLAW_WEBHOOK_SECRET=vos-hooks-token-2026

# === Resend (REQUIRED — outbound email) ===
RESEND_API_KEY=re_your-key

# === Email Webhook ===
EMAIL_WEBHOOK_SECRET=nbdigital-mail-2026

# === Vapi (voice AI — optional) ===
VAPI_TOKEN=your-vapi-token

# === SearchAPI (web search — optional) ===
SEARCHAPI_TOKEN=your-searchapi-token

# === Slack (REQUIRED for agent communication) ===
SLACK_APP_TOKEN=xapp-your-token
SLACK_BOT_TOKEN=xoxb-your-token

# === MoChat (agent chat platform) ===
MOCHAT_TOKEN=claw_your-mochat-token
MOCHAT_BOT_USER_ID=your-bot-user-id

# === GitHub (agent code access) ===
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your-token

# === Apollo.io (lead enrichment — optional) ===
APOLLO_API_KEY=your-apollo-key

# === Firecrawl (SEO crawling — optional) ===
FIRECRAWL_API_KEY=fc-your-key

# === Mem0 (agent memory — optional) ===
MEM0_API_KEY=m0-your-key

# === Stripe (billing — not yet connected) ===
# STRIPE_SECRET_KEY=sk_test_your-key
# STRIPE_WEBHOOK_SECRET=whsec_your-secret
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key

# === Trigger.dev (background jobs) ===
TRIGGER_API_KEY=tr_dev_your-key
TRIGGER_API_URL=https://api.trigger.dev

# === Cal.com (booking) ===
# CAL_API_KEY=cal_your-key

# === App ===
NEXT_PUBLIC_SITE_URL=https://www.thenorthbridgemi.com
NEXT_PUBLIC_DEFAULT_ORGANIZATION_ID=00000000-0000-0000-0000-000000000001
NODE_ENV=development
